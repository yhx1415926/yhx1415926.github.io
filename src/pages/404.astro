---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";

/* 白昼旅途语录 */
const dayQuotes = [
  "清晨的风有点温柔呢——就算是最美丽的魔女，也会偶尔飞错方向。",
  "阳光正好，我却带你闯进了一条陌生的小街……看来旅途又多了一站。",
  "午后的云慢慢飘着，迷路只是旅行里最可爱的插曲。",
  "身为最优秀的旅行者，我也会在白昼里小小偏航一下。",
  "地图之外的世界闪闪发光，也许那里正等着我们。",
  "别担心啦，现在还是白天，这只是一次计划外的小冒险。",
  "风吹过屋顶的时候，我意识到——啊，我们走错路了呢。",
];


/* 夜旅语录 */
const nightQuotes = [
  "夜色降临啦，就连最美丽的魔女，也会在星光里短暂迷失。",
  "月亮已经升起，我们好像悄悄拐进了夜之街道。",
  "深夜的风有点凉，不过别怕，我依然优雅地飞着。",
  "星空拉长了距离，但不会终结旅途——只是换成了夜航模式。",
  "也许这个页面已经睡着了，而我正带你进行一次午夜散步。",
  "街灯一盏一盏亮起的时候，我才发现……嗯，好像走反方向了。",
  "现在是属于夜晚的旅途呢，迷路也要保持从容。",
];

---

<MainGridLayout title="404" description="Page not found">
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-96">
    <div class="card-base z-10 px-9 py-12 relative w-full flex flex-col items-center justify-center text-center">

      <div class="text-8xl md:text-9xl font-bold text-(--primary) opacity-20 mb-4">
        404
      </div>

      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-90">
        看来，这是一段意料之外的旅途
      </h1>

      <p id="travel-quote" class="travel-quote text-lg text-75 mb-4 max-w-md"></p>

      <p class="text-sm text-60 mb-8 italic">
        —— 来自旅行中的灰之魔女
      </p>

      <a
        href={url("/")}
        class="inline-flex items-center gap-2 px-6 py-3 bg-(--primary) text-white rounded-(--radius-large) hover:bg-(--btn-content) transition-colors duration-200 font-medium"
      >
        <Icon name="material-symbols:home" class="text-xl" />
        重新启程
      </a>

      <div class="absolute top-4 left-4 opacity-10">
        <Icon name="material-symbols:sentiment-sad" class="text-4xl text-(--primary)" />
      </div>

      <div class="absolute bottom-4 right-4 opacity-10">
        <Icon name="material-symbols:search-off" class="text-4xl text-(--primary)" />
      </div>

    </div>
  </div>
</MainGridLayout>

<script define:vars={{ dayQuotes, nightQuotes }} is:inline>
  const hour = new Date().getHours();
  const isNight = hour < 6 || hour >= 18;

  const pool = isNight ? nightQuotes : dayQuotes;
  const el = document.getElementById("travel-quote");

  let lastIndex = -1;

  function nextQuote() {
    let i;
    do {
      i = Math.floor(Math.random() * pool.length);
    } while (i === lastIndex && pool.length > 1);

    lastIndex = i;

    if (!el) return;

    el.classList.remove("show");

    setTimeout(() => {
      el.textContent = pool[i];
      requestAnimationFrame(() => el.classList.add("show"));
    }, 200);
  }

  // 初始显示
  nextQuote();

  // 每 8 秒轮播一次（旅途广播）
  setInterval(nextQuote, 8000);
</script>

<style>
.card-base {
  animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 语录淡入 + 漂浮 */
.travel-quote {
  opacity: 0;
  transform: translateY(6px);
  transition: transform 0.3s ease;
}

.travel-quote.show {
  opacity: 1;
  transform: translateY(0);
  transition:
    opacity 0.8s ease,
    transform 0.8s ease;
  animation: gentleFloat 6s ease-in-out infinite;
}

/* 鼠标靠近上浮 */
.travel-quote:hover {
  transform: translateY(-4px);
}

@keyframes gentleFloat {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4px);
  }
  100% {
    transform: translateY(0);
  }
}

a:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(var(--primary-rgb), 0.3);
}
</style>
